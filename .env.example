# Discord Bot設定
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord Webhook URL（GitHub Actions定期通知用）
DISCORD_WEBHOOK_URL=your_webhook_url_here

# Discord チャンネルID
OPERATION_CHANNEL_ID=your_operation_channel_id
NOTIFICATION_CHANNEL_ID=your_notification_channel_id

# Google Sheets設定
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# 公式サイト通知用 Webhook URL
DISCORD_WEBSITE_WEBHOOK_URL=your_website_webhook_url_here

# YouTube通知用 Webhook URL
DISCORD_YOUTUBE_WEBHOOK_URL=your_youtube_webhook_url_here

# YouTubeチャンネルID（UCで始まる文字列）
YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here

# Twitter通知用 Webhook URL
DISCORD_TWITTER_WEBHOOK_URL=your_twitter_webhook_url_here

# Twitterユーザー名（@なし）
TWITTER_USERNAME=denpaningen

# RSSHub ベースURL（セルフホスト時に指定。省略時は https://rsshub.app を使用）
# RSSHUB_BASE_URL=https://rsshub.app

# 固定メッセージID（初回起動後に自動設定されます。空のままにしてください）
CONTROL_MESSAGE_ID=
